# Auto-detect text files and use LF
* text=auto eol=lf

# Explicitly set LF for known text types
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf

# Binary files - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.bmp binary
*.pth binary
*.onnx binary
*.pyc binary
